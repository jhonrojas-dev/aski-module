<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="aski_connector.Systray" owl="1">
        <div class="ac-systray">
            <button class="ac-systray-btn" t-on-click="toggle" title="Aski">
                <i class="fa fa-comments"/>
            </button>
            <div t-if="state.open" class="ac-floating-panel">
                <button class="ac-floating-close" t-on-click="toggle" title="Close">
                    <i class="fa fa-times"/>
                </button>
                <AskiChatWidget/>
            </div>
        </div>
    </t>
</templates>
