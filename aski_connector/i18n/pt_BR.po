#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "<b>How to connect:</b>"
msgstr "<b>Como conectar:</b>"

#. module: aski_connector
#: model:ir.model,name:aski_connector.model_aski_connect_wizard
msgid "Aski connection assistant"
msgstr "Assistente de conexão do Aski"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid ""
"Aski lets you ask your ERP in plain language and get real\n"
"                        figures in seconds — sales, receivables, top products and\n"
"                        more — from your phone, even by voice."
msgstr "O Aski permite perguntar ao seu ERP em linguagem natural e obter números reais em segundos — vendas, contas a receber, produtos mais vendidos e mais — pelo celular, até por voz."

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "Click <b>Generate connection code</b> below."
msgstr "Clique em <b>Gerar código de conexão</b> abaixo."

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "Close"
msgstr "Fechar"

#. module: aski_connector
#: model:ir.ui.menu,name:aski_connector.menu_aski_connect
msgid "Connect"
msgstr "Conectar"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "Connect this Odoo with Aski"
msgstr "Conecte este Odoo ao Aski"

#. module: aski_connector
#: model:ir.actions.act_window,name:aski_connector.action_aski_connect
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "Connect with Aski"
msgstr "Conectar com o Aski"

#. module: aski_connector
#: model:ir.model.fields,field_description:aski_connector.field_aski_connect_wizard__token
msgid "Connection code"
msgstr "Código de conexão"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "Don't have the app yet? Get it on"
msgstr "Ainda não tem o app? Baixe na"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_code
msgid "Done"
msgstr "Concluído"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "Generate connection code"
msgstr "Gerar código de conexão"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid ""
"Open the <b>Aski</b> app on your phone and choose\n"
"                            <b>Scan code</b>."
msgstr "Abra o app <b>Aski</b> no seu celular e escolha <b>Escanear código</b>."

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_code
msgid "Or paste this code manually in the app:"
msgstr "Ou cole este código manualmente no app:"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "Point the camera at the QR. Done — no typing."
msgstr "Aponte a câmera para o QR. Pronto — sem digitar."

#. module: aski_connector
#: model:ir.model.fields,field_description:aski_connector.field_aski_connect_wizard__qr_image
msgid "QR code"
msgstr "Código QR"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_code
msgid "Scan this code in the Aski app"
msgstr "Escaneie este código no app Aski"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_code
msgid ""
"This code grants API access to this Odoo as your user.\n"
"                        Don't share it. You can revoke it anytime in\n"
"                        Settings &gt; Users &amp; Companies &gt; your user &gt;\n"
"                        Account Security &gt; API Keys."
msgstr "Este código concede acesso de API a este Odoo como seu usuário. Não o compartilhe. Você pode revogá-lo a qualquer momento em Configurações &gt; Usuários e empresas &gt; seu usuário &gt; Segurança da conta &gt; Chaves de API."

#. module: aski_connector
#. odoo-python
#: code:addons/aski_connector/models/aski_connect_wizard.py:0
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_code
msgid "Your Aski connection code"
msgstr "Seu código de conexão do Aski"

#. module: aski_connector
#: model_terms:ir.ui.view,arch_db:aski_connector.view_aski_connect_intro
msgid "or learn more at"
msgstr "ou saiba mais em"
