<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard: crear la cuenta aqui mismo, o pegar un token existente -->
    <record id="view_aski_chat_connect_wizard" model="ir.ui.view">
        <field name="name">aski.chat.connect.wizard</field>
        <field name="model">aski.chat.connect.wizard</field>
        <field name="arch" type="xml">
            <form string="Connect Aski chat">
                <sheet>
                    <div class="oe_title">
                        <h1>Connect the Aski chat</h1>
                    </div>
                    <p><b>Aski</b> is an AI assistant that answers questions about your Odoo in plain language - sales, receivables, top products and more. Ask from your phone, from the web, or right here inside Odoo.</p>
                    <group>
                        <field name="mode" widget="radio"/>
                    </group>

                    <!-- Alta sin salir de Odoo -->
                    <group invisible="mode != 'signup'">
                        <field name="signup_email" placeholder="you@company.com"
                               required="mode == 'signup'"/>
                        <field name="signup_password" password="True"
                               placeholder="At least 8 characters"
                               required="mode == 'signup'"/>
                        <field name="signup_password_confirm" password="True"
                               placeholder="Type it again"
                               required="mode == 'signup'"/>
                        <field name="signup_partner_code"
                               placeholder="Only if a partner gave you one"/>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="mode != 'signup'">
                        The account is created with that email and this Odoo is connected right away. It's the <b>same</b> account you'll use in the Aski mobile app and on the web, with the same credits - nothing else to sign up for.
                    </div>

                    <!-- Token existente -->
                    <!-- Sin widget CopyClipboardChar: ese widget es para COPIAR
                         un valor, y aqui el usuario PEGA el suyo. Ademas se
                         comia el placeholder y el borde del input, dejando el
                         campo practicamente invisible (no se veia donde pegar). -->
                    <group invisible="mode != 'token'">
                        <field name="pat" placeholder="ask_pat_..."
                               required="mode == 'token'"/>
                    </group>
                    <p invisible="mode != 'token'">Generate a <b>Personal access token</b> in the Aski web app (<b>app.aski.dev</b> &gt; Settings &gt; Personal access tokens) and paste it above. This Odoo is then registered as a connection under your Aski account.</p>

                    <group>
                        <field name="name" placeholder="e.g. Production - Head office"/>
                    </group>
                    <p>The connection name is how this Odoo shows up in your Aski connections list, on your phone and on the web - so you can tell it apart from your other instances.</p>

                    <div class="alert alert-info" role="alert"><b>Your data stays private.</b> Who can use the chat - and whose data they see - is set by the administrator in Aski &gt; Chat Settings: share one connection with a group, keep it to administrators only, or let each person connect their own Aski account and see only what their own Odoo user can.</div>
                    <div class="alert alert-warning" role="alert">
                        <field name="partner_managed" invisible="1"/>
                        <p class="mb-0" invisible="partner_managed">Chat usage spends credits from that Aski account's wallet - the same plan used by the Aski mobile app and web. See all plans and pricing at <a href="https://aski.dev/?utm_source=odoo&amp;utm_medium=aski_connector&amp;utm_campaign=chat_wizard_pricing#pricing" target="_blank">aski.dev/#pricing</a>, or buy and top up credits at <a href="https://app.aski.dev/billing?utm_source=odoo&amp;utm_medium=aski_connector&amp;utm_campaign=chat_wizard_billing" target="_blank">app.aski.dev/billing</a>.</p>
                        <p class="mb-0" invisible="not partner_managed">Your Aski plan and credits are managed by your partner - contact them for plan changes or top-ups.</p>
                    </div>
                </sheet>
                <footer>
                    <button name="action_create_account" type="object" class="btn-primary"
                            invisible="mode != 'signup'">Create my account and connect</button>
                    <button name="action_connect" type="object" class="btn-primary"
                            invisible="mode != 'token'">Connect Aski</button>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_aski_chat_connect" model="ir.actions.act_window">
        <field name="name">Connect Aski chat</field>
        <field name="res_model">aski.chat.connect.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aski_chat_connect_wizard"/>
        <field name="target">new</field>
    </record>

    <!-- Settings: estado de la conexion (reconectar / probar) -->
    <record id="view_aski_account_link_form" model="ir.ui.view">
        <field name="name">aski.account.link.form</field>
        <field name="model">aski.account.link</field>
        <field name="arch" type="xml">
            <form string="Aski chat settings">
                <sheet>
                    <div class="oe_title">
                        <h1>Aski chat connection</h1>
                    </div>
                    <group>
                        <field name="access_mode"/>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="access_mode != 'per_user'">
                        <b>Per user:</b> each internal user connects their own Aski account from the chat's <b>Connect</b> button (Aski &gt; Chat). Aski then only sees what their own Odoo user can see, and each person spends their own credits - nothing else to set up here.
                    </div>
                    <group invisible="access_mode == 'per_user'">
                        <field name="connected" widget="boolean_toggle" readonly="1"/>
                        <field name="plan_name" readonly="1"/>
                        <field name="wallet_credits" readonly="1"/>
                        <field name="last_synced" readonly="1"/>
                    </group>
                    <field name="partner_managed" invisible="1"/>
                    <div class="text-muted" style="margin-top:8px;" invisible="partner_managed">
                        See all plans and pricing at <a href="https://aski.dev/?utm_source=odoo&amp;utm_medium=aski_connector&amp;utm_campaign=settings_pricing#pricing" target="_blank">aski.dev/#pricing</a>, or buy and top up credits at <a href="https://app.aski.dev/billing?utm_source=odoo&amp;utm_medium=aski_connector&amp;utm_campaign=settings_billing" target="_blank">app.aski.dev/billing</a>.
                    </div>
                    <div class="text-muted" style="margin-top:8px;" invisible="not partner_managed">
                        Your Aski plan and credits are managed by your partner - contact them for plan changes or top-ups.
                    </div>
                </sheet>
                <footer>
                    <!-- Save: persiste el modo en per_user (ahi los demas botones se ocultan); type=object guarda el registro antes de llamar. Sin el, cambiar a per_user se descartaba al Close. -->
                    <button name="action_save_settings" type="object"
                            string="Save" class="btn-primary"/>
                    <button name="action_test_connection" type="object"
                            string="Test connection" class="btn-secondary"
                            invisible="access_mode == 'per_user'"/>
                    <button name="%(action_aski_chat_connect)d" type="action"
                            string="Reconnect / paste a new token" class="btn-secondary"
                            invisible="access_mode == 'per_user'"/>
                    <button name="action_disconnect" type="object"
                            string="Disconnect" class="btn-secondary"
                            confirm="Disconnect this Aski account? You can reconnect anytime with your token."
                            invisible="access_mode == 'per_user' or not connected"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- El id viejo (action_aski_account_link) era un ir.actions.act_window
         estatico sin res_id -> abria un formulario NUEVO y vacio en vez de la
         conexion ya guardada; se borro en la 1.1.3 (no se puede reusar el
         mismo id para otro modelo) y se reemplazo por este ir.actions.server,
         que resuelve el singleton real en runtime (_get_or_create) antes de
         abrirlo. El <delete> de esa migracion ya cumplio su proposito (queda
         solo en el historial de git) — dejarlo aqui solo generaria un warning
         de "external id ya no existe" en cada instalacion nueva. -->
    <record id="action_aski_account_link_open" model="ir.actions.server">
        <field name="name">Aski chat settings</field>
        <field name="model_id" ref="model_aski_account_link"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_settings()</field>
    </record>

    <!-- Chat widget (OWL, estilo Discuss) -->
    <record id="action_aski_chat" model="ir.actions.client">
        <field name="name">Chat</field>
        <field name="tag">aski_chat_widget</field>
    </record>

    <!-- El menu es visible a todo usuario interno: en modo "por usuario"
         cualquiera puede conectar su cuenta. La restriccion real por modo la
         aplican los guards del backend + los estados del widget; la burbuja del
         systray si queda precisa (usa can_use_chat, que es mode-aware).
         El "-group_aski_chat_user" quita el gateo anterior (el groups= de
         menuitem SUMA, no reemplaza) — asi no queda redundante en upgrades;
         en instalacion nueva el unlink es no-op. -->
    <menuitem id="menu_aski_chat" name="Chat" parent="aski_connector.menu_aski_root"
              action="action_aski_chat" sequence="5"
              groups="base.group_user,-aski_connector.group_aski_chat_user"/>

    <!-- Hasta la 1.6.0, un post_init_hook desactivaba ESTE menu en Odoo 14/15
         (se daba por hecho que el widget OWL no podia cargar ahi). Ya no es
         cierto: el chat corre en 14-19. Las instalaciones que quedaron con el
         menu oculto tienen `active=False` guardado en BD, y un `menuitem` no
         toca ese campo al actualizar -> seguirian sin ver el chat. Este record
         lo fuerza a True en cada actualizacion. -->
    <record id="menu_aski_chat" model="ir.ui.menu">
        <field name="active" eval="True"/>
    </record>
    <menuitem id="menu_aski_chat_settings" name="Chat Settings"
              parent="aski_connector.menu_aski_root"
              action="action_aski_account_link_open" sequence="20"
              groups="base.group_system"/>

</odoo>
